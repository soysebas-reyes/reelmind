# Dependencies
node_modules/

# Build output
out/
dist/
release/
.vite/
*.tsbuildinfo

# Bundled FFmpeg binaries (fetched at build time via `npm run fetch:ffmpeg`, redistributed under GPL)
resources/ffmpeg/

# Upstream clone kept only as a local porting reference — never published
reference/

# Client-confidential color assets — LUTs + reference docs, never commit (see docs/COLOR_GRADING_PLAN.md §9.5.3)
Guia_Colorizacion/
**/luts/*.cube
*.cube

# Secrets & local env (API keys are stored via Windows safeStorage/DPAPI, never committed)
.env
.env.*
!.env.example
secrets.bin
*.local

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Project media/cache produced at runtime
*.vproj/cache/
